{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RawHID Host",
  "version": "0.3.1",
  "identifier": "com.rawhid-host.app",
  "build": {
    "beforeDevCommand": {
      "script": "npm run dev",
      "cwd": "../../ui"
    },
    "beforeBuildCommand": {
      "script": "npm run build",
      "cwd": "../../ui"
    },
    "frontendDist": "../../ui/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "RawHID Host",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
